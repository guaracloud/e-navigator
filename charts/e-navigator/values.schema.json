{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "namespace": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "image": { "$ref": "#/definitions/image" },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "object" }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "toml": { "type": "string", "minLength": 1 }
      }
    },
    "args": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "logLevel": { "type": "string", "minLength": 1 },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "resources": { "type": "object" },
    "securityContext": { "type": "object" },
    "hostPaths": { "type": "object" }
  },
  "definitions": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[a-f0-9]{64}$"
        },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    }
  }
}
