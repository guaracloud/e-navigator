{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "health": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        },
        "required": ["health"]
      },
      "then": {
        "properties": {
          "prometheusHttp": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        },
        "required": ["prometheusHttp"]
      }
    }
  ],
  "properties": {
    "namespace": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "image": { "$ref": "#/definitions/image" },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "object" }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "toml": { "type": "string", "minLength": 1 }
      }
    },
    "args": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "logLevel": { "type": "string", "minLength": 1 },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 1, "maximum": 300 },
    "priorityClassName": { "type": "string" },
    "minReadySeconds": { "type": "integer", "minimum": 0, "maximum": 300 },
    "revisionHistoryLimit": { "type": "integer", "minimum": 0, "maximum": 20 },
    "updateStrategy": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["RollingUpdate", "OnDelete"] },
        "rollingUpdate": { "type": "object" }
      }
    },
    "features": { "type": "object" },
    "hostPID": { "type": "boolean" },
    "hostNetwork": { "type": "boolean" },
    "dnsPolicy": { "type": "string", "minLength": 1 },
    "affinity": { "type": "object" },
    "resources": { "type": "object" },
    "securityContext": { "type": "object" },
    "prometheusHttp": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "startupPath": { "type": "string", "pattern": "^/" },
        "livenessPath": { "type": "string", "pattern": "^/" },
        "readinessPath": { "type": "string", "pattern": "^/" },
        "startupPeriodSeconds": { "type": "integer", "minimum": 1 },
        "startupFailureThreshold": { "type": "integer", "minimum": 1 },
        "livenessPeriodSeconds": { "type": "integer", "minimum": 1 },
        "livenessFailureThreshold": { "type": "integer", "minimum": 1 },
        "readinessPeriodSeconds": { "type": "integer", "minimum": 1 },
        "readinessFailureThreshold": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "service": { "type": "object" },
    "serviceMonitor": { "type": "object" },
    "hostPaths": { "type": "object" }
  },
  "definitions": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[a-f0-9]{64}$"
        },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    }
  }
}
